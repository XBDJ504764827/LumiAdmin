DATABASE_URL=postgres://user:pass@localhost:5432/manger
BIND_ADDR=0.0.0.0:3001
DEV_USERNAME=dev
DEV_PASSWORD=change-me
HTTP_TIMEOUT_SECS=300
REQUEST_TIMEOUT_SECS=300

# 全球封禁同步起始时间（RFC3339 格式）
# 只有该时间之后新增的全球封禁才会被同步到 LumiAdmin 封禁管理。
# 留空则使用首次部署这版后端的时间作为起始点。
# 示例：GLOBAL_BAN_SYNC_SINCE=2025-06-13T00:00:00Z
# GLOBAL_BAN_SYNC_SINCE=

# 全球封禁同步间隔（秒，默认 300 = 5 分钟）
GLOBAL_BAN_SYNC_INTERVAL_SECS=300

# Request body limit should be higher than the largest appeal file because
# multipart uploads include small boundary/header overhead.
APPEAL_FILE_MAX_SIZE_MB=100
MAX_REQUEST_BODY_BYTES=115343360

# Cloudflare R2 / S3-compatible storage for ban appeal evidence files.
# Leave these empty to disable file upload without affecting other features.
R2_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
R2_BUCKET=example-bucket
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_CUSTOM_DOMAIN=https://files.example.com
R2_TOKEN_VALUE=
